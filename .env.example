# 집잡아(JipJaba) environment variables
#
# ── Where each var belongs in production ──────────────────────────────
#  Next.js (Vercel):   AGENT_SERVICE_URL  (+ optional AIRTABLE_* if /api/crm
#                       ever reads Airtable directly — it doesn't by default)
#  Agent service (Railway/Render/Fly):  ANTHROPIC_API_KEY, AIRTABLE_*,
#                       INTENT_MODEL, RESPONSE_MODEL, SUGGEST_MODEL,
#                       JIPJABA_CHECKPOINT_PATH
# Locally you can keep everything in one .env (subprocess fallback is used).

# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-...

# --- CRM (Airtable) ---
AIRTABLE_API_KEY=pat...
AIRTABLE_BASE_ID=app...
AIRTABLE_TABLE_NAME=Consultations

# --- Model overrides (optional) ---
INTENT_MODEL=claude-sonnet-4-6
RESPONSE_MODEL=claude-sonnet-4-6
# A lighter/faster model for follow-up suggestion chips is fine here:
SUGGEST_MODEL=claude-sonnet-4-6

# --- Deployment wiring ---
# Set on the Next.js (Vercel) project to proxy chat/crm to the Python service.
# Leave UNSET locally to use the Python subprocess fallback.
AGENT_SERVICE_URL=https://your-agent-service.example.com

# Set on the agent service to persist conversation memory on a mounted volume.
# JIPJABA_CHECKPOINT_PATH=/data/checkpoints.sqlite
